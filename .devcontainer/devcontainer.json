{
  "name": "podcast-forge",
  "image": "ghcr.io/gatezh/devcontainer-claude-bun:latest",
  "runArgs": [
    "--cap-add=NET_ADMIN",
    "--cap-add=NET_RAW"
  ],
  "features": {
    "ghcr.io/devcontainers/features/git:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "Anthropic.claude-code",
        "ms-vscode.js-debug",
        "ms-vscode.npm"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "workbench.colorCustomizations": {
          "titleBar.activeBackground": "#E64A19",
          "titleBar.inactiveBackground": "#FF5722",
          "titleBar.activeForeground": "#000",
          "titleBar.inactiveForeground": "#000"
        }
      }
    }
  },
  "postCreateCommand": "bun install",
  "remoteUser": "bun",
  "mounts": [
    "source=claude-code-bashhistory-${devcontainerId},target=/commandhistory,type=volume",
    "source=claude-code-config-${devcontainerId},target=/home/bun/.claude,type=volume"
  ],
  "containerEnv": {
    "CLAUDE_CONFIG_DIR": "/home/bun/.claude"
  },
  "postStartCommand": "sudo /usr/local/bin/init-firewall.sh"
}